#!/bin/sh
# on-host-podman - queue podman host commands via the sensible task queue.
# Usage: on-host-podman <command> [args]
# Commands: commit, commit_and_switch, switch, restart, reset_and_switch
#
# The actual podman command runs on the host (via the sensible
# protocol); the agent calls this from inside the container.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CONTAINER=$(hostname)

CMD="${1?Usage: on-host-podman <command>}"
shift
TAG="${1:-next}"

case "$CMD" in
  commit)
    "$SCRIPT_DIR/on-host-sensible-do" \
      "podman commit $CONTAINER localhost/goclaw:$TAG"
    ;;
  commit_and_switch)
    "$SCRIPT_DIR/on-host-sensible-do" \
      'if { podman rmi localhost/goclaw:previous } true' \
      'if { podman tag localhost/goclaw:current localhost/goclaw:previous } true' \
      "podman commit $CONTAINER localhost/goclaw:$TAG" \
      "if { podman tag localhost/goclaw:$TAG localhost/goclaw:current } true" \
      'podman restart $CONTAINER'
    ;;
  switch)
    "$SCRIPT_DIR/on-host-sensible-do" \
      'if { podman rmi localhost/goclaw:previous } true' \
      'if { podman tag localhost/goclaw:current localhost/goclaw:previous } true' \
      "if { podman tag localhost/goclaw:$TAG localhost/goclaw:current } true" \
      'podman restart $CONTAINER'
    ;;
  restart)
    "$SCRIPT_DIR/on-host-sensible-do" 'podman restart $CONTAINER'
    ;;
  reset_and_switch)
    # Reset to base image and restart
    "$SCRIPT_DIR/on-host-sensible-do" \
      'if { podman rmi localhost/goclaw:previous } true' \
      'if { podman tag localhost/goclaw:current localhost/goclaw:previous } true' \
      'if { podman tag localhost/goclaw:base localhost/goclaw:current } true' \
      'podman restart $CONTAINER'
    ;;
  *)
    echo "Unknown command: $CMD" >&2
    echo "Usage: on-host-podman <commit|commit_and_switch|switch|restart|reset_and_switch> [tag]" >&2
    exit 1
    ;;
esac
