#!/usr/bin/env bash
#
# Test for on-host-podman
# Tests: commit, switch, restart, reset_and_switch

. "$(dirname "$0")/lib/bash-spec.sh"

PODMAN_ON_HOST="$(cd "$(dirname "$0")/../shared-sbin" && pwd)/on-host-podman"
TEST_TASKS_DIR="/tmp/test-podman-$$"
TASKS_PENDING="$TEST_TASKS_DIR/pending"

cleanup() {
  rm -rf "$TEST_TASKS_DIR" 2>/dev/null || true
}

describe "on-host-podman" && {

  cleanup

  context "1. commit command" && {
    it "queues rmi, tag, and commit tasks" && {
      export HOST_TASKS_DIR="$TEST_TASKS_DIR"
      mkdir -p "$TASKS_PENDING"

      "$PODMAN_ON_HOST" commit 2>&1

      # rmi :previous, tag :current → :previous, commit container → :current
      JSON_FILES=("$TASKS_PENDING"/*.json)
      [ ${#JSON_FILES[@]} -eq 3 ]
      should_succeed
    }
  }

  context "2. switch command" && {
    it "queues rmi, tag, and promote tasks" && {
      export HOST_TASKS_DIR="$TEST_TASKS_DIR"
      rm -rf "$TEST_TASKS_DIR"
      mkdir -p "$TASKS_PENDING"

      "$PODMAN_ON_HOST" switch previous 2>&1

      # rmi :previous, tag :current → :previous, tag :previous → :current
      JSON_FILES=("$TASKS_PENDING"/*.json)
      [ ${#JSON_FILES[@]} -eq 3 ]
      should_succeed
    }
  }

  context "3. restart command" && {
    it "queues restart task" && {
      export HOST_TASKS_DIR="$TEST_TASKS_DIR"
      rm -rf "$TEST_TASKS_DIR"
      mkdir -p "$TASKS_PENDING"

      "$PODMAN_ON_HOST" restart 2>&1

      JSON_FILES=("$TASKS_PENDING"/*.json)
      [ ${#JSON_FILES[@]} -eq 1 ]
      should_succeed
    }
  }

  context "4. reset_and_switch command" && {
    it "queues rmi, tag, base-promote, and restart tasks" && {
      export HOST_TASKS_DIR="$TEST_TASKS_DIR"
      rm -rf "$TEST_TASKS_DIR"
      mkdir -p "$TASKS_PENDING"

      "$PODMAN_ON_HOST" reset_and_switch 2>&1

      # rmi :previous, tag :current → :previous, tag :base → :current,
      # restart
      JSON_FILES=("$TASKS_PENDING"/*.json)
      [ ${#JSON_FILES[@]} -eq 4 ]
      should_succeed
    }
  }

  context "5. usage error" && {
    it "shows usage when no args" && {
      "$PODMAN_ON_HOST" 2>&1 | grep -q "Usage:"
      should_fail
    }

    it "shows error for unknown command" && {
      "$PODMAN_ON_HOST" badcmd 2>&1 | grep -q "Unknown command:"
      should_fail
    }
  }

  context "cleanup" && {
    it "removes test directory" && {
      cleanup
      [ ! -d "$TEST_TASKS_DIR" ]
      should_succeed
    }
  }
}