#!/bin/sh
# add-gh: install GitHub CLI
# Usage: add-gh [--version]
#   --version - print the version that would be installed (no install)
#
# Strategy: apk (Alpine community repo). The package is named `github-cli`,
# not `gh`. Version 2.83.0 is the newest in alpine 3.23 community.
#
# To get a newer version, switch to the curl-from-upstream approach
# (commented out below).
#
# Installs: github-cli 2.83.0 (provides `gh` binary)
set -e

if [ "${1:-}" = "--version" ]; then
    echo "gh 2.83.0 (github-cli 2.83.0 in apk) (install via add-gh)"
    exit 0
fi

sudo apk add --no-cache github-cli

