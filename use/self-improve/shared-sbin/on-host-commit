#!/bin/sh
# on-host-commit - persist the container's state by committing the image.
#
# The agent calls this from inside the container; the actual podman
# commit runs on the host (via the sensible task queue). The container
# is NOT restarted by this command — run `podman compose down && up`
# (or `on-host-podman restart`) afterwards to activate the new image.
#
# Usage: on-host-commit
#
# Workflow:
#   1. Agent makes changes in the container (apk add, pip install, etc.)
#   2. Agent runs `on-host-commit`
#   3. The host's sensible process picks up the queued task and runs an
#      atomic swap: snapshot :current → :previous, then commit the
#      container's read-write layer directly into a new :current image.
#   4. Run `podman compose down && up` to launch the new :current.
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

exec "$SCRIPT_DIR/on-host-podman" commit