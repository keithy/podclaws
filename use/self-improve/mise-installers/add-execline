#!/bin/sh
# add-execline: install execline (minimalist shell)
# Usage: add-execline [--version]
#   --version - print the version that would be installed (no install)
#
# Strategy: OS package manager. mise doesn't install execline (it's a
# system tool, not a language runtime). Both apk (Alpine) and apt
# (Debian bookworm) ship it.
set -e

detect_pkg_mgr() {
    if command -v apk >/dev/null 2>&1; then echo apk
    elif command -v apt-get >/dev/null 2>&1; then echo apt
    else echo none
    fi
}

if [ "${1:-}" = "--version" ]; then
    case "$(detect_pkg_mgr)" in
        apk)
            ver=$(apk policy execline 2>/dev/null | awk '/^[[:space:]]+[0-9]/ {print $1; exit}' | sed 's/-r.*//')
            if [ -n "$ver" ]; then
                echo "execline $ver (apk) (install via add-execline)"
            else
                echo "execline (apk version unknown) (install via add-execline)"
            fi
            ;;
        apt)
            ver=$(apt-cache policy execline 2>/dev/null | awk '/^[[:space:]]+Candidate:/ {print $2; exit}')
            if [ -n "$ver" ] && [ "$ver" != "(none)" ]; then
                echo "execline $ver (apt) (install via add-execline)"
            else
                echo "execline (apt version unknown) (install via add-execline)"
            fi
            ;;
        *) echo "execline (no installer available) (install via add-execline)" ;;
    esac
    exit 0
fi

case "$(detect_pkg_mgr)" in
    apk) sudo apk add --no-cache execline ;;
    apt) sudo apt-get update -qq && sudo apt-get install -y --no-install-recommends execline ;;
    *)   echo "add-execline: no supported package manager found" >&2; exit 1 ;;
esac
