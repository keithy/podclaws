#!/bin/sh
# add-mise: install mise (https://mise.jdx.dev/) version manager
# Usage: add-mise [--version]
#   --version - print the version that would be installed (no install)
#
# Strategy: read the mise binary from the docker volume `mise-glibc`
# (mounted at /usr/share/mise/ in the container). The volume's
# `latest` symlink is managed by use/mise/Makefile (host-side); bumping
# the mise version on the host updates the symlink, and the next
# container recreate picks up the new binary without any shim change.
#
# Install to the container's writable layer:
#   - /bin/mise   (so which mise returns /bin/mise)
#
# /bin/mise is wiped on podman compose down (writable layer gone), so
# add-mise re-runs on every container recreate. /bin is the same place
# where /bin/goclaw is bind-mounted, keeping mise and goclaw together.
#
# mise 2026.6.x is statically linked — no separate lua lib is needed.
# (The Alpine variant's lua staging is gone; the glibc mise never
# needed a separate lua lib.)
#
# Note: same script body as the Alpine variant — distro-agnostic.
set -e

# Source: the docker volume `mise-glibc` (mounted at /usr/share/mise).
# The `latest` symlink is updated by use/mise/Makefile on the host.
MISE_SRC=/usr/share/mise/RELEASES/mise/latest/aarch64/mise

# Destination: the container's writable layer.
MISE_DST=/bin/mise

# Copy the mise binary. /bin is the container's image filesystem
# (writable via root, not a volume mount). sudo needed for write access.
if [ -f "$MISE_SRC" ] && [ ! -x "$MISE_DST" ]; then
    sudo cp "$MISE_SRC" "$MISE_DST"
    sudo chmod +x "$MISE_DST"
fi

if [ "${1:-}" = "--version" ]; then
    # Read the version from the `latest` symlink so the UI probe
    # sees a real version string, not a hardcoded literal.
    ver=$(readlink /usr/share/mise/RELEASES/mise/latest 2>/dev/null || echo unknown)
    echo "mise $ver (install via add-mise)"
    exit 0
fi

if [ ! -x "$MISE_DST" ]; then
    echo "add-mise: no mise binary at $MISE_DST" >&2
    echo "  source: $MISE_SRC" >&2
    exit 1
fi

# Exec the installed mise binary.
exec "$MISE_DST" "$@"
