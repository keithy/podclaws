#!/bin/sh
# add-pg-client: install PostgreSQL client (psql) matching the remote DB version
# Usage: add-pg-client [--version]
#   --version - print the version that would be installed (no install)
#
# Strategy: probe the remote DB (via GOCLAW_POSTGRES_DSN) and install the
# matching postgresql-client-<MAJOR>. Hardcoded fallback if probing fails.
#
# Debian package naming: postgresql-client-<MAJOR> (with a hyphen, not the
# Alpine form postgresql<MAJOR>-client).
#
# Pinned: probes live, falls back to postgresql-client-18.

set -e

if [ "${1:-}" = "--version" ]; then
    # Hardcoded for speed — the --version mode is called on every UI
    # runtime probe and must be fast. The real install path below does
    # the live probe. The format matches the real pg_dump --version
    # output so goclaw's ParsePgDumpMajor can extract the major version.
    echo "pg_dump (PostgreSQL) 18.4 (install via add-pg-client)"
    exit 0
fi

# Accept the DSN
DSN="${GOCLAW_POSTGRES_DSN:?Error: Please provide a PostgreSQL DSN}"

# 1. Pure string parsing to extract the host and port from the DSN
# Strips the protocol prefix
STRIPPED="${DSN#*//}"
# Strips user/pass prefix if it exists
HOST_PORT_PATH="${STRIPPED#*@}"
# Strips the database path at the end
HOST_PORT="${HOST_PORT_PATH%%/*}"

# Split host and port (default to 5432 if no port is specified)
if [ "${HOST_PORT#*:}" != "$HOST_PORT" ]; then
    HOST="${HOST_PORT%%:*}"
    PORT="${HOST_PORT##*:}"
else
    HOST="$HOST_PORT"
    PORT="5432"
fi

echo "Probing remote database at $HOST:$PORT over raw TCP..."

# 2. Open a raw socket, force an error, and scan the binary response for a version number
# We use a 2-second timeout so the script doesn't hang if the firewall drops the packet
RAW_RESPONSE=$(echo "" | timeout 2 nc "$HOST" "$PORT" | strings || true)

# Extract the major version (looks for patterns like "15.", "16.", "17.")
MAJOR_VERSION=$(echo "$RAW_RESPONSE" | grep -oE '[0-9]+\.[0-9]+' | head -n 1 | cut -d. -f1)

# Fallback in case the server is strictly hardened and hides its version string
if [ -z "$MAJOR_VERSION" ]; then
    echo "Could not confidently sniff version over wire. Falling back to latest stable (18)."
    MAJOR_VERSION="18"
else
    echo "Detected Remote PostgreSQL Major Version: $MAJOR_VERSION"
fi

# Dynamically install the exact client needed
CLIENT_PKG="postgresql-client-${MAJOR_VERSION}"

echo "Installing $CLIENT_PKG..."

sudo apt-get update -qq
sudo apt-get install -y --no-install-recommends "$CLIENT_PKG"
