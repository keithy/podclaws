#!/bin/sh
# add-oils: install Oil shell
# Usage: add-oils [--version]
#   --version - print the version that would be installed (no install)
#
# Strategy: build from source. Requires build tooling + curl.
# Version pinned: oils-for-unix-0.37.0
# Distro-agnostic: same body, different build-deps install commands.
set -e

if [ "${1:-}" = "--version" ]; then
    echo "oils-for-unix 0.37.0 (build from source, takes 1-2 minutes) (install via add-oils)"
    exit 0
fi

detect_pkg_mgr() {
    if command -v apk >/dev/null 2>&1; then echo apk
    elif command -v apt-get >/dev/null 2>&1; then echo apt
    else echo none
    fi
}

# 1. Install build dependencies
case "$(detect_pkg_mgr)" in
    apk)
        sudo apk add --no-cache --virtual build-deps build-base curl
        CLEANUP="sudo apk del --no-cache build-deps"
        ;;
    apt)
        sudo apt-get update -qq
        sudo apt-get install -y --no-install-recommends build-essential curl ca-certificates
        CLEANUP="sudo apt-get remove --purge -y build-essential && sudo apt-get autoremove -y"
        ;;
    *)
        echo "add-oils: no supported package manager found" >&2
        exit 1
        ;;
esac

sudo mkdir -p /usr/local/lib/oils_src
sudo chown -R $(id -u):$(id -g) /usr/local/lib/oils_src

# 2. Grab the source tarball
curl -fsSL https://oils.pub/download/oils-for-unix-0.37.0.tar.gz |
  tar -xz --strip-components=1 -C /usr/local/lib/oils_src

cd /usr/local/lib/oils_src

mkdir tmp
TMPDIR=./tmp

sudo chown -R $(id -u):$(id -g) /usr/local/lib/oils_src

# 3. Configure, build, and install
./configure
_build/oils.sh

# Optional: run unit tests
./test/unit.sh

sudo ./install

# 4. Cleanup build deps
eval "$CLEANUP"
