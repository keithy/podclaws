#!/bin/sh
# add-office: install office tools (pandoc, poppler-utils)
set -e

ensure-buildah

CTR_NAME="office-build"

echo "→ Creating buildah container..."
buildah rm "$CTR_NAME" 2>/dev/null || true
buildah from --name "$CTR_NAME" containers-storage:localhost/self-buildah:latest

echo "→ Installing office tools..."
buildah run "$CTR_NAME" -- apk add --no-cache pandoc poppler-utils

echo "→ Committing as :latest..."
buildah commit "$CTR_NAME" localhost/self-buildah:latest

echo "→ Cleaning up..."
buildah rm "$CTR_NAME"

echo "✅ Office tools layer done"