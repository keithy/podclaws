#!/bin/sh
# add-python: install Python runtime
# Usage: add-python [base|full]
#   base  - python3 + pip (default; what the shim uses)
#   full  - all Python skill deps (pandas, pypdf, openpyxl, etc.)
#   --version - print the version that would be installed (no install)
#
# Strategy: apt (Debian package repo). Bookworm ships Python 3.11, which
# is OLDER than the Alpine variant (3.12). Debian's pip package is
# python3-pip; python3-venv is needed for `python3 -m venv`.
# Installs: python3 3.11.x, python3-pip, python3-venv
set -e

if [ "${1:-}" = "--version" ]; then
    py_ver=$(apt-cache policy python3 2>/dev/null | awk '/^[[:space:]]+Candidate:/ {print $2; exit}')
    pip_ver=$(apt-cache policy python3-pip 2>/dev/null | awk '/^[[:space:]]+Candidate:/ {print $2; exit}')
    if [ -z "$py_ver" ] || [ "$py_ver" = "(none)" ]; then
        echo "python (version unknown — apt index empty, run 'sudo apt-get update' to refresh)"
        exit 0
    fi
    [ -n "$pip_ver" ] && [ "$pip_ver" != "(none)" ] && pip_ver="pip $pip_ver"
    echo "python $py_ver, ${pip_ver:-pip (unknown)} (install via add-python)"
    exit 0
fi

MODE="${1:-base}"

echo "Installing Python runtime ($MODE)..."

# Base installation applies to all modes
sudo apt-get update -qq
sudo apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    python3-venv \
    python3-dev

case "${MODE}" in
    full)
        # Debian's pip is restricted to system-managed environments by
        # default (PEP 668). Need --break-system-packages for the same
        # behavior as the Alpine variant, OR use a venv.
        for pkg in \
            "pypdf~=6.9.2" \
            "openpyxl~=3.1.5" \
            "python-pptx~=1.0.2" \
            "pdfplumber~=0.11.9" \
            "pdf2image~=1.17.0" \
            "markitdown<0.2.0" \
            "pandas~=3.0.2" \
            "defusedxml~=0.7.1" \
            "lxml~=6.0.2" \
            "anthropic>=0.88.0,<2.0.0"; do

            pip3 install --no-cache-dir --break-system-packages "$pkg"
        done
        ;;
esac

echo "Python $MODE installed successfully"
