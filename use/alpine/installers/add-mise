#!/bin/sh
# add-mise: passthrough to the mise binary at /usr/share/mise/bin/mise.
#
# That path is a symlink managed by use/mise/Makefile on the host:
#   /usr/share/mise/bin/mise → ../RELEASES/mise/latest/aarch64/mise
# which in turn points to /usr/share/mise/RELEASES/mise/<VERSION>/aarch64/mise.
# Bumping the mise version on the host updates the symlink; this
# shim never needs to change.
#
# mise itself is in the container's PATH (at /usr/share/mise/bin,
# when +mise-improve.yml is in use) so goclaw's exec.Command("mise", ...)
# resolves directly without copying. This shim is kept for callers that
# reach add-mise by name from the installer dir (/usr/local/bin/add-mise).
#
# Note: mise 2026.6.x is statically linked, so no separate lua lib is
# needed.
exec /usr/share/mise/bin/mise "$@"
