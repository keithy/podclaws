#!/bin/sh
# add-gh: install GitHub CLI
# Usage: add-gh [--version]
#   --version - print the version that would be installed (no install)
#
# Strategy: OS package manager. mise has no plugin for gh; the github-cli
# backend (aqua) requires a different setup that's not worth the complexity
# here. Stick with the native package.
# Installs: github-cli 2.x (apk) / gh 2.x (apt)
set -e

detect_pkg_mgr() {
    if command -v apk >/dev/null 2>&1; then echo apk
    elif command -v apt-get >/dev/null 2>&1; then echo apt
    else echo none
    fi
}

if [ "${1:-}" = "--version" ]; then
    case "$(detect_pkg_mgr)" in
        apk)
            ver=$(apk policy github-cli 2>/dev/null | awk '/^[[:space:]]+[0-9]/ {print $1; exit}' | sed 's/-r.*//')
            if [ -n "$ver" ]; then
                echo "gh $ver (github-cli in apk) (install via add-gh)"
            else
                echo "gh (apk version unknown) (install via add-gh)"
            fi
            ;;
        apt)
            ver=$(apt-cache policy gh 2>/dev/null | awk '/^[[:space:]]+Candidate:/ {print $2; exit}')
            if [ -n "$ver" ] && [ "$ver" != "(none)" ]; then
                echo "gh $ver (apt) (install via add-gh)"
            else
                echo "gh (apt version unknown) (install via add-gh)"
            fi
            ;;
        *) echo "gh (no installer available) (install via add-gh)" ;;
    esac
    exit 0
fi

case "$(detect_pkg_mgr)" in
    apk) sudo apk add --no-cache github-cli ;;
    apt) sudo apt-get update -qq && sudo apt-get install -y --no-install-recommends gh ;;
    *)   echo "add-gh: no supported package manager found" >&2; exit 1 ;;
esac
