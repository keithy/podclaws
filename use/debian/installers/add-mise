#!/bin/sh
# add-mise: install mise (https://mise.jdx.dev/) version manager.
#
# Resolution order:
#   1. /usr/share/mise/bin/mise (set up by +mise-improve.yml via bind-mount
#      from the mise-glibc volume; managed on the host by use/mise/Makefile)
#   2. /usr/local/bin/mise (fallback if the volume isn't available)
#   3. Bootstrap: download from upstream and install to whichever of
#      /usr/share/mise/bin or /usr/local/bin is writable
#
# mise itself is in the container's PATH (at /usr/share/mise/bin when
# +mise-improve.yml is in use) so goclaw's exec.Command("mise", ...)
# resolves directly. This shim is the bootstrap path when mise isn't
# pre-staged.
#
# Pinned version: MISE_VERSION=2026.6.13 (default). Override with the
# MISE_VERSION env var in the compose file if you need a different
# version. mise 2026.6.x is statically linked — no lua lib needed.
#
# Note: same script body as the Alpine variant — distro-agnostic.
set -e

MISE_VERSION="${MISE_VERSION:-2026.6.13}"
MISE_TARBALL="mise-v${MISE_VERSION}-linux-arm64.tar.gz"
MISE_URL="https://github.com/jdx/mise/releases/download/v${MISE_VERSION}/${MISE_TARBALL}"
SHASUMS_URL="https://github.com/jdx/mise/releases/download/v${MISE_VERSION}/SHASUMS256.txt"

# 1. mise already bind-mounted from the mise-glibc volume?
if [ -x /usr/share/mise/bin/mise ]; then
    exec /usr/share/mise/bin/mise "$@"
fi

# 2. mise already installed at /usr/local/bin (e.g. previous shim run)?
if [ -x /usr/local/bin/mise ]; then
    exec /usr/local/bin/mise "$@"
fi

# 3. Bootstrap: download from upstream, verify SHA256, install.
work=$(mktemp -d)
trap 'rm -rf "$work"' EXIT

if ! command -v curl >/dev/null 2>&1; then
    echo "add-mise: curl is required for bootstrap" >&2
    exit 1
fi

curl -fsSL -o "$work/$MISE_TARBALL" "$MISE_URL" || {
    echo "add-mise: failed to download $MISE_TARBALL" >&2
    exit 1
}
curl -fsSL -o "$work/SHASUMS256.txt" "$SHASUMS_URL" || {
    echo "add-mise: failed to download SHASUMS256.txt" >&2
    exit 1
}

expected=$(grep -F "./$MISE_TARBALL" "$work/SHASUMS256.txt" | awk '{print $1}')
actual=$(sha256sum "$work/$MISE_TARBALL" | awk '{print $1}')
if [ -z "$expected" ] || [ "$expected" != "$actual" ]; then
    echo "add-mise: SHA256 mismatch for $MISE_TARBALL" >&2
    [ -n "$expected" ] && echo "  expected: $expected" >&2
    echo "  actual:   $actual" >&2
    exit 1
fi

tar -xzf "$work/$MISE_TARBALL" -C "$work"

# Install to /usr/share/mise/bin if the volume is mounted (mise mode),
# else fall back to /usr/local/bin (native mode).
if mountpoint -q /usr/share/mise 2>/dev/null || [ -d /usr/share/mise ]; then
    target=/usr/share/mise/bin/mise
else
    target=/usr/local/bin/mise
fi

sudo install -d -m 0755 "$(dirname "$target")"
sudo install -m 0755 "$work/mise/bin/mise" "$target"

exec "$target" "$@"
