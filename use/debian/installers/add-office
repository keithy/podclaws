#!/bin/sh
# add-office: install office tools (pandoc, poppler-utils)
# Usage: add-office [--version]
#   --version - print the versions that would be installed (no install)
#
# Strategy: apt (Debian package repo). Same package names as Alpine.
# Installs: pandoc 2.9.x (bookworm), poppler-utils 22.12.x
set -e

if [ "${1:-}" = "--version" ]; then
    pandoc_ver=$(apt-cache policy pandoc 2>/dev/null | awk '/^[[:space:]]+Candidate:/ {print $2; exit}')
    poppler_ver=$(apt-cache policy poppler-utils 2>/dev/null | awk '/^[[:space:]]+Candidate:/ {print $2; exit}')
    [ -z "$pandoc_ver" ] || [ "$pandoc_ver" = "(none)" ] && pandoc_ver="(unknown)"
    [ -z "$poppler_ver" ] || [ "$poppler_ver" = "(none)" ] && poppler_ver="(unknown)"
    echo "pandoc $pandoc_ver, poppler-utils $poppler_ver (install via add-office)"
    exit 0
fi

sudo apt-get update -qq
sudo apt-get install -y --no-install-recommends pandoc poppler-utils
