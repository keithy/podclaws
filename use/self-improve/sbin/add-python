#!/bin/sh
# add-python: install Python runtime
# Usage: add-python [base|full]
#   base  - python3 + pip (default; what the shim uses)
#   full  - all Python skill deps (pandas, pypdf, openpyxl, etc.)
#   --version - print the version that would be installed (no install)
#
# Strategy: apk (Alpine package repo).
# Installs: python 3.12.13, pip 25.1.1
set -e

if [ "${1:-}" = "--version" ]; then
    # apk policy prints the header "<pkg> policy:" then the version on
    # the next line, indented. Grab the first indented non-empty line.
    py_ver=$(apk policy python3 2>/dev/null | awk '/^[[:space:]]+[0-9]/ {print $1; exit}' | sed 's/-r.*//')
    pip_ver=$(apk policy py3-pip 2>/dev/null | awk '/^[[:space:]]+[0-9]/ {print $1; exit}' | sed 's/-r.*//')
    if [ -z "$py_ver" ]; then
        echo "python (version unknown — apk index empty, run 'sudo apk update' to refresh)"
        exit 0
    fi
    [ -n "$pip_ver" ] && pip_ver="pip $pip_ver"
    echo "python $py_ver, ${pip_ver:-pip (unknown)} (install via add-python)"
    exit 0
fi

MODE="${1:-base}"

echo "Installing Python runtime ($MODE)..."

# Base installation applies to all modes
sudo apk add --no-cache python3 py3-pip

case "${MODE}" in
    full)
        for pkg in \
            "pypdf~=6.9.2" \
            "openpyxl~=3.1.5" \
            "python-pptx~=1.0.2" \
            "pdfplumber~=0.11.9" \
            "pdf2image~=1.17.0" \
            "markitdown<0.2.0" \
            "pandas~=3.0.2" \
            "defusedxml~=0.7.1" \
            "lxml~=6.0.2" \
            "anthropic>=0.88.0,<2.0.0"; do

            pip3 install --no-cache-dir --break-system-packages "$pkg"
        done
        ;;
esac

echo "Python $MODE installed successfully"
